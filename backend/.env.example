# ─── Port Configurations ──────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Mongoose DB Configurations ───────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/trulicare

# ─── JSON Web Token Secret ──────────────────────────────────────────────────
# Cryptographically secure random secret (e.g. generate via openssl rand -base64 64)
JWT_SECRET=

# ─── Email Notification Settings ──────────────────────────────────────────────
# SMTP configurations for alert dispatches (Gmail, Sendgrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Trulicare <your_email@gmail.com>

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generated using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your_email@gmail.com

# ─── Twilio SMS/WhatsApp (Optional) ───────────────────────────────────────────
# If blank, dispatches are simulated inside the console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=
