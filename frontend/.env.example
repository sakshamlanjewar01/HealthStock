# ─── Google OAuth Configuration ───────────────────────────────────────────────
# API & Services > Credentials client ID (https://console.cloud.google.com/)
VITE_GOOGLE_CLIENT_ID=

# ─── API Connection Settings ──────────────────────────────────────────────────
# Path prefix to connect to the backend REST API
VITE_API_URL=http://localhost:5000/api

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Public VAPID key matching the backend's key (generated via npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=
